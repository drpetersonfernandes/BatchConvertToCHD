<Window x:Class="BatchConvertToCHD.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Batch Convert to CHD"
        Height="800" Width="1000" MinHeight="650" MinWidth="700"
        Closing="Window_Closing"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- 0: Header -->
            <RowDefinition Height="*" />    <!-- 1: Main Content -->
            <RowDefinition Height="Auto" /> <!-- 2: StatusBar -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBackgroundBrush}" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Batch Convert to CHD" Style="{StaticResource HeaderTitleStyle}" Margin="0,0,30,0" ToolTip="Batch process disc image files to CHD format" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Click="AboutMenuItem_Click" Style="{StaticResource ActionButtonStyle}" Background="{StaticResource AboutButtonBrush}" ToolTip="View application information and acknowledgements">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="pack://application:,,,/images/about.png" Width="16" Height="16" Margin="0,0,5,0" ToolTip="Open the About window" />
                                <TextBlock Text="About" Style="{StaticResource ButtonContentTextStyle}" ToolTip="Open the About window" />
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <Button Click="ExitMenuItem_Click" Style="{StaticResource ActionButtonStyle}" Background="{StaticResource ExitButtonBrush}" ToolTip="Close the application">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="pack://application:,,,/images/exit.png" Width="16" Height="16" Margin="0,0,5,0" ToolTip="Close the application" />
                                <TextBlock Text="Exit" Style="{StaticResource ButtonContentTextStyle}" ToolTip="Close the application" />
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />    <!-- 0: Main Area (Tabs + Log) -->
                <RowDefinition Height="Auto" /> <!-- 1: Stats Panel -->
                <RowDefinition Height="Auto" /> <!-- 2: Progress Area -->
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="400" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" MinWidth="300" />
                </Grid.ColumnDefinitions>

                <TabControl Grid.Column="0" x:Name="MainTabControl" SelectionChanged="MainTabControl_SelectionChanged" ToolTip="Switch between Convert, Verify, and Extract operations">
                    <TabItem Header="Convert to CHD" x:Name="ConvertTab" ToolTip="Batch convert various disc image formats to CHD">
                        <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="0,0,6,6" Padding="15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" /> <!-- Input -->
                                    <RowDefinition Height="Auto" /> <!-- Output -->
                                    <RowDefinition Height="Auto" /> <!-- Options -->
                                    <RowDefinition Height="Auto" /> <!-- Label -->
                                    <RowDefinition Height="*" />    <!-- DataGrid -->
                                    <RowDefinition Height="Auto" /> <!-- Buttons -->
                                    <RowDefinition Height="Auto" /> <!-- Start -->
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Label Content="Source Files:" ToolTip="Select the folder containing files you want to convert" />
                                    <TextBox x:Name="ConversionInputFolderTextBox" Grid.Column="1" Margin="5,0" IsReadOnly="True" ToolTip="The selected folder path for conversion input" />
                                    <Button x:Name="BrowseConversionInputButton" Grid.Column="2" Content="Browse" Click="BrowseConversionInputButton_Click" Style="{StaticResource ActionButtonStyle}" ToolTip="Browse" />
                                </Grid>

                                <Grid Grid.Row="1" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Label Content="Output CHD:" ToolTip="Select where the converted CHD files should be saved" />
                                    <TextBox x:Name="ConversionOutputFolderTextBox" Grid.Column="1" Margin="5,0" IsReadOnly="True" ToolTip="The selected folder path for CHD output" />
                                    <Button x:Name="BrowseConversionOutputButton" Grid.Column="2" Content="Browse" Click="BrowseConversionOutputButton_Click" Style="{StaticResource ActionButtonStyle}" ToolTip="Browse" />
                                </Grid>

                                <Expander Grid.Row="2" Header="Options" Margin="0,5,0,5" IsExpanded="False" ToolTip="Configure conversion settings">
                                    <GroupBox Padding="10" Margin="0,5,0,0">
                                        <StackPanel>
                                        <CheckBox x:Name="SearchSubfoldersConversionCheckBox" Content="Search subfolders (recursive search)" Margin="0,2" HorizontalAlignment="Left" ToolTip="Recursively search for files in all subfolders"
                                                  Checked="SearchSubfoldersCheckBox_Changed" Unchecked="SearchSubfoldersCheckBox_Changed" />
                                        <CheckBox x:Name="DeleteOriginalsCheckBox" Content="Delete originals after a successful conversion" Margin="0,2" HorizontalAlignment="Left" VerticalAlignment="Top"
                                                  ToolTip="Automatically delete source files once they are successfully converted to CHD" />
                                        <CheckBox x:Name="ProcessSmallerFirstCheckBox" Content="Process smaller files first" Margin="0,2" HorizontalAlignment="Left" ToolTip="Sort files by size and process the smallest ones first" />
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <CheckBox x:Name="EnableConversionTimeoutCheckBox" Content="Time limit per file:" ToolTip="Abort conversion of a file if it exceeds the specified time limit" VerticalAlignment="Center" VerticalContentAlignment="Center"/>
                                            <TextBox x:Name="ConversionTimeoutTextBox" Width="60" Text="15" Margin="5,0,0,0" ToolTip="Timeout in minutes per file (default: 15)" VerticalAlignment="Center" VerticalContentAlignment="Center"/>
                                            <TextBlock Text="minutes" Margin="5,0,0,0" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" ToolTip="Time limit unit in minutes"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <CheckBox x:Name="ForceCreateCdCheckBox" Content="Force CD" Margin="0,0,10,0" Checked="ForceCreateCdCheckBox_Checked" ToolTip="Force CHDMAN to use the 'createcd' command" />
                                            <CheckBox x:Name="ForceCreateDvdCheckBox" Content="Force DVD" Checked="ForceCreateDvdCheckBox_Checked" ToolTip="Force CHDMAN to use the 'createdvd' command" />
                                        </StackPanel>
                                    </StackPanel>
                                    </GroupBox>
                                </Expander>

                                <Label Grid.Row="3" Content="Select Files to Convert:" Margin="0,5,0,0" Style="{StaticResource SectionLabelStyle}" ToolTip="Mark or unmark files to include in the batch conversion" />
                                <DataGrid Grid.Row="4" x:Name="ConversionFilesDataGrid" Margin="0,5" AutoGenerateColumns="False" ToolTip="List of files available for conversion. Select files to include in batch processing.">
                                    <DataGrid.Columns>
                                        <DataGridCheckBoxColumn Header="Select" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="80" HeaderStyle="{StaticResource SelectColumnHeaderStyle}" />
                                        <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*" IsReadOnly="True" HeaderStyle="{StaticResource FileNameColumnHeaderStyle}" />
                                        <DataGridTextColumn Header="Size" Binding="{Binding DisplaySize}" Width="130" IsReadOnly="True" HeaderStyle="{StaticResource FileSizeColumnHeaderStyle}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                                    <Button Content="Select All" Click="SelectAllConversion_Click" Style="{StaticResource ActionButtonStyle}" Margin="5,0" ToolTip="Select all files in the list" />
                                    <Button Content="Deselect All" Click="DeselectAllConversion_Click" Style="{StaticResource ActionButtonStyle}" Margin="5,0" ToolTip="Deselect all files in the list" />
                                </StackPanel>

                                <Button Grid.Row="6" x:Name="StartConversionButton" Content="Start Conversion" Click="StartConversionButton_ClickAsync" Style="{StaticResource StartButtonStyle}" HorizontalAlignment="Stretch" ToolTip="Begin the batch conversion process" />
                            </Grid>
                        </Border>
                    </TabItem>

                    <TabItem Header="Verify CHD" x:Name="VerifyTab" ToolTip="Verify the integrity of existing CHD files">
                        <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="0,0,6,6" Padding="15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" /> <!-- Input -->
                                    <RowDefinition Height="Auto" /> <!-- Options -->
                                    <RowDefinition Height="Auto" /> <!-- Label -->
                                    <RowDefinition Height="*" />    <!-- DataGrid -->
                                    <RowDefinition Height="Auto" /> <!-- Buttons -->
                                    <RowDefinition Height="Auto" /> <!-- Start -->
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Label Content="CHD Files:" ToolTip="Select the folder containing the CHD files you want to verify" />
                                    <TextBox x:Name="VerificationInputFolderTextBox" Grid.Column="1" Margin="5,0" IsReadOnly="True" ToolTip="The selected folder path for verification" />
                                    <Button x:Name="BrowseVerificationInputButton" Grid.Column="2" Content="Browse" Click="BrowseVerificationInputButton_Click" Style="{StaticResource ActionButtonStyle}" ToolTip="Browse" />
                                </Grid>

                                <Expander Grid.Row="1" Header="Options" Margin="0,5,0,5" IsExpanded="False" ToolTip="Configure verification settings">
                                    <GroupBox Padding="10" Margin="0,5,0,0">
                                        <StackPanel>
                                            <CheckBox x:Name="SearchSubfoldersVerificationCheckBox" Content="Search subfolders (recursive search)" Margin="0,2" HorizontalAlignment="Left" ToolTip="Recursively search for files in all subfolders"
                                                      Checked="SearchSubfoldersCheckBox_Changed" Unchecked="SearchSubfoldersCheckBox_Changed" />
                                            <CheckBox x:Name="MoveSuccessFilesCheckBox" Content="Move successful to 'Success' folder" Margin="0,2" HorizontalAlignment="Left" ToolTip="Move CHD files that pass verification into a 'Success' subfolder" />
                                            <CheckBox x:Name="MoveFailedFilesCheckBox" Content="Move failed to 'Failed' folder" Margin="0,2" HorizontalAlignment="Left" ToolTip="Move CHD files that fail verification into a 'Failed' subfolder" />
                                        </StackPanel>
                                    </GroupBox>
                                </Expander>

                                <Label Grid.Row="2" Content="Select Files to Verify:" Margin="0,5,0,0" Style="{StaticResource SectionLabelStyle}" ToolTip="Mark or unmark files to include in the batch verification" />
                                <DataGrid Grid.Row="3" x:Name="VerificationFilesDataGrid" Margin="0,5" AutoGenerateColumns="False" ToolTip="List of CHD files available for verification. Select files to include in batch verification.">
                                    <DataGrid.Columns>
                                        <DataGridCheckBoxColumn Header="Select" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="80" HeaderStyle="{StaticResource SelectColumnHeaderStyle}" />
                                        <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*" IsReadOnly="True" HeaderStyle="{StaticResource FileNameColumnHeaderStyle}" />
                                        <DataGridTextColumn Header="Size" Binding="{Binding DisplaySize}" Width="130" IsReadOnly="True" HeaderStyle="{StaticResource FileSizeColumnHeaderStyle}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                                    <Button Content="Select All" Click="SelectAllVerification_Click" Style="{StaticResource ActionButtonStyle}" Margin="5,0" ToolTip="Select all files in the list" />
                                    <Button Content="Deselect All" Click="DeselectAllVerification_Click" Style="{StaticResource ActionButtonStyle}" Margin="5,0" ToolTip="Deselect all files in the list" />
                                </StackPanel>

                                <Button Grid.Row="5" x:Name="StartVerificationButton" Content="Start Verification" Click="StartVerificationButton_ClickAsync" Style="{StaticResource StartButtonStyle}" HorizontalAlignment="Stretch" ToolTip="Begin the batch verification process" />
                            </Grid>
                        </Border>
                    </TabItem>

                    <TabItem Header="Extract" x:Name="ExtractTab" ToolTip="Extract CHD files back to their original formats">
                        <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="0,0,6,6" Padding="15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" /> <!-- Input -->
                                    <RowDefinition Height="Auto" /> <!-- Output -->
                                    <RowDefinition Height="Auto" /> <!-- Options -->
                                    <RowDefinition Height="Auto" /> <!-- Label -->
                                    <RowDefinition Height="*" />    <!-- DataGrid -->
                                    <RowDefinition Height="Auto" /> <!-- Buttons -->
                                    <RowDefinition Height="Auto" /> <!-- Start -->
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Label Content="CHD Files:" ToolTip="Select the folder containing CHD files for extraction" />
                                    <TextBox x:Name="ExtractionInputFolderTextBox" Grid.Column="1" Margin="5,0" IsReadOnly="True" ToolTip="The selected folder path for extraction input" />
                                    <Button x:Name="BrowseExtractionInputButton" Grid.Column="2" Content="Browse" Click="BrowseExtractionInputButton_Click" Style="{StaticResource ActionButtonStyle}" ToolTip="Browse" />
                                </Grid>

                                <Grid Grid.Row="1" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Label Content="Output Folder:" ToolTip="Select the folder where extracted files will be saved" />
                                    <TextBox x:Name="ExtractionOutputFolderTextBox" Grid.Column="1" Margin="5,0" IsReadOnly="True" ToolTip="The selected folder path for extraction output" />
                                    <Button x:Name="BrowseExtractionOutputButton" Grid.Column="2" Content="Browse" Click="BrowseExtractionOutputButton_Click" Style="{StaticResource ActionButtonStyle}" ToolTip="Browse" />
                                </Grid>

                                <Expander Grid.Row="2" Header="Options" Margin="0,5,0,5" IsExpanded="False" ToolTip="Configure extraction settings">
                                    <Grid Margin="0,5,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <GroupBox Grid.Row="0" Grid.Column="0" Header="Format" Margin="0,0,5,0" Padding="10" ToolTip="Select the output format for extracted files">
                                            <StackPanel Orientation="Vertical">
                                                <RadioButton x:Name="ExtractAutoRadioButton" Content="Auto" IsChecked="True" Margin="0,1" ToolTip="Detect automatically" GroupName="ExtractFormat" />
                                                <RadioButton x:Name="ExtractCdRadioButton" Content="CD (.cue)" Margin="0,1" ToolTip="Force CD image extraction" GroupName="ExtractFormat" />
                                                <RadioButton x:Name="ExtractDvdRadioButton" Content="DVD (.iso)" Margin="0,1" ToolTip="Force DVD image extraction" GroupName="ExtractFormat" />
                                                <RadioButton x:Name="ExtractGdiRadioButton" Content="GDI (.gdi)" Margin="0,1" ToolTip="Force Dreamcast GDI extraction" GroupName="ExtractFormat" />
                                                <RadioButton x:Name="ExtractHdRadioButton" Content="HDD (.img)" Margin="0,1" ToolTip="Force Hard Disk extraction" GroupName="ExtractFormat" />
                                            </StackPanel>
                                        </GroupBox>

                                        <GroupBox Grid.Row="0" Grid.Column="1" Header="Options" Margin="5,0,0,0" Padding="10" ToolTip="Configure extraction settings">
                                            <StackPanel>
                                                <CheckBox x:Name="SearchSubfoldersExtractionCheckBox" Content="Search subfolders (recursive search)" Margin="0,2" HorizontalAlignment="Left" ToolTip="Recursively search for files in all subfolders"
                                                          Checked="SearchSubfoldersCheckBox_Changed" Unchecked="SearchSubfoldersCheckBox_Changed" />
                                                <CheckBox x:Name="DeleteOriginalChdCheckBox" Content="Delete original CHD after a successful extraction" Margin="0,2" HorizontalAlignment="Left" VerticalAlignment="Top" ToolTip="Delete original CHD after a successful extraction" />
                                            </StackPanel>
                                        </GroupBox>
                                    </Grid>
                                </Expander>

                                <Label Grid.Row="3" Content="Select Files to Extract:" Margin="0,5,0,0" Style="{StaticResource SectionLabelStyle}" ToolTip="Mark or unmark files to include in the batch extraction" />
                                <DataGrid Grid.Row="4" x:Name="ExtractionFilesDataGrid" Margin="0,5" AutoGenerateColumns="False" ToolTip="List of CHD files available for extraction. Select files to include in batch extraction.">
                                    <DataGrid.Columns>
                                        <DataGridCheckBoxColumn Header="Select" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="80" HeaderStyle="{StaticResource SelectColumnHeaderStyle}" />
                                        <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*" IsReadOnly="True" HeaderStyle="{StaticResource FileNameColumnHeaderStyle}" />
                                        <DataGridTextColumn Header="Size" Binding="{Binding DisplaySize}" Width="130" IsReadOnly="True" HeaderStyle="{StaticResource FileSizeColumnHeaderStyle}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                                    <Button Content="Select All" Click="SelectAllExtraction_Click" Style="{StaticResource ActionButtonStyle}" Margin="5,0" ToolTip="Select all files in the list" />
                                    <Button Content="Deselect All" Click="DeselectAllExtraction_Click" Style="{StaticResource ActionButtonStyle}" Margin="5,0" ToolTip="Deselect all files in the list" />
                                </StackPanel>

                                <Button Grid.Row="6" x:Name="StartExtractionButton" Content="Start Extraction" Click="StartExtractionButton_ClickAsync" Style="{StaticResource StartButtonStyle}" HorizontalAlignment="Stretch" ToolTip="Begin the batch extraction process" />
                            </Grid>
                        </Border>
                    </TabItem>
                </TabControl>

                <GridSplitter Grid.Column="1" Width="10" HorizontalAlignment="Stretch" ToolTip="Drag to resize the log panel" />

                <Border Grid.Column="2" BorderBrush="{StaticResource TerminalBorderBrush}" BorderThickness="2" CornerRadius="4" Background="{StaticResource TerminalBackgroundBrush}" ToolTip="Real-time application activity log">
                    <TextBox x:Name="LogViewer"
                             Style="{StaticResource TerminalLogTextBoxWithGlow}"
                             ToolTip="Application activity log" />
                </Border>
            </Grid>

            <Grid Grid.Row="1" Margin="0,15,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource StatCard}" ToolTip="Total number of files to process">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="TOTAL FILES" Style="{StaticResource StatLabelStyle}" Foreground="{StaticResource TextSecondaryBrush}" ToolTip="Total number of files selected for processing" />
                        <TextBlock x:Name="TotalFilesValue" Text="0" Style="{StaticResource StatValueStyle}" Foreground="{StaticResource TextPrimaryBrush}" ToolTip="Number of files detected in the current batch" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource StatCard}" ToolTip="Number of successfully processed files">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="SUCCESS" Style="{StaticResource StatLabelSuccessStyle}" ToolTip="Number of files that were successfully processed" />
                        <TextBlock x:Name="SuccessValue" Text="0" Style="{StaticResource StatValueSuccessStyle}" ToolTip="Count of files that completed without errors" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource StatCard}" ToolTip="Number of files that failed processing">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="FAILED" Style="{StaticResource StatLabelFailedStyle}" ToolTip="Number of files that failed during processing" />
                        <TextBlock x:Name="FailedValue" Text="0" Style="{StaticResource StatValueFailedStyle}" ToolTip="Count of files that encountered errors" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource StatCard}" ToolTip="Total processing time">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="ELAPSED" Style="{StaticResource StatLabelStyle}" Foreground="{StaticResource TextSecondaryBrush}" ToolTip="Total time elapsed during the current or last batch operation" />
                        <TextBlock x:Name="ProcessingTimeValue" Text="00:00:00" Style="{StaticResource StatValueStyle}" Foreground="{StaticResource TextPrimaryBrush}" ToolTip="The total processing time in HH:MM:SS format" />
                    </StackPanel>
                </Border>

                <Border x:Name="SpeedStatCard" Grid.Column="4" Style="{StaticResource StatCard}" ToolTip="Average processing speed">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="SPEED" Style="{StaticResource StatLabelStyle}" Foreground="{StaticResource TextSecondaryBrush}" ToolTip="Average processing speed of the current batch operation" />
                        <TextBlock x:Name="SpeedValue" Text="0.0 MB/s" Style="{StaticResource StatValueStyle}" Foreground="{StaticResource TextPrimaryBrush}" ToolTip="The average throughput in megabytes per second" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid x:Name="ProgressAreaGrid" Grid.Row="2" Margin="0,15,0,0" Visibility="Collapsed" ToolTip="Processing progress and cancel button area. Visible only during batch operations.">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="1" Background="{StaticResource CardBackgroundBrush}" ToolTip="Processing progress indicator">
                    <Grid>
                        <ProgressBar x:Name="ProgressBar" Height="28" Foreground="{StaticResource ProgressForegroundBrush}" Background="{StaticResource ProgressBackgroundBrush}" BorderThickness="0" ToolTip="Overall processing progress" />
                        <TextBlock x:Name="ProgressText" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" ToolTip="Currently processing file details" />
                    </Grid>
                </Border>
                <Button x:Name="CancelButton" Grid.Column="1" Content="Cancel" Style="{StaticResource CancelButtonStyle}" Margin="10,0,0,0" Click="CancelButton_Click" ToolTip="Stop the current operation" />
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Background="{StaticResource StatusBarBackgroundBrush}" Padding="5" ToolTip="Status bar showing application state and external tool availability">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>

            <StatusBarItem Grid.Column="0">
                <TextBlock x:Name="StatusBarMessage" Text="Ready" Foreground="{StaticResource TextSecondaryBrush}" ToolTip="Current application status" />
            </StatusBarItem>

            <StatusBarItem Grid.Column="1" ToolTip="Status of required external tools">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Dependencies:" Margin="0,0,5,0" Foreground="{StaticResource TextSecondaryBrush}" ToolTip="External tools required for processing" />
                    <TextBlock x:Name="StatusBarChdman" Text="CHDMAN" Foreground="{StaticResource SuccessTextBrush}" Margin="0,0,5,0" ToolTip="Status of chdman.exe" />
                    <TextBlock Text="|" Margin="0,0,5,0" Foreground="{StaticResource TextMutedBrush}" ToolTip="Separator" />
                    <TextBlock x:Name="StatusBarMaxcso" Text="MAXCSO" Foreground="{StaticResource SuccessTextBrush}" Margin="0,0,5,0" ToolTip="Status of maxcso.exe" />
                    <TextBlock Text="|" Margin="0,0,5,0" Foreground="{StaticResource TextMutedBrush}" ToolTip="Separator" />
                    <TextBlock x:Name="StatusBarPsxPackager" Text="PSXPACKAGER" Foreground="{StaticResource SuccessTextBrush}" Margin="0" ToolTip="Status of psxpackager.exe" />
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>