<Window x:Class="BatchConvertToCHD.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Batch Convert to CHD"
        Height="800" Width="1000" MinHeight="650" MinWidth="700"
        Closing="Window_Closing"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- 0: Header -->
            <RowDefinition Height="*" />    <!-- 1: Main Content -->
            <RowDefinition Height="Auto" /> <!-- 2: StatusBar -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBackgroundBrush}" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Batch Convert to CHD" FontSize="20" FontWeight="Bold" Foreground="{StaticResource HeaderTextBrush}" VerticalAlignment="Center" Margin="0,0,30,0" />
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Click="AboutMenuItem_Click" Style="{StaticResource ActionButtonStyle}" Background="{StaticResource AboutButtonBrush}" ToolTip="View application information">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="pack://application:,,,/images/about.png" Width="16" Height="16" Margin="0,0,5,0" />
                                <TextBlock Text="About" Foreground="#121518" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <Button Click="ExitMenuItem_Click" Style="{StaticResource ActionButtonStyle}" Background="{StaticResource ExitButtonBrush}" ToolTip="Close the application">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="pack://application:,,,/images/exit.png" Width="16" Height="16" Margin="0,0,5,0" />
                                <TextBlock Text="Exit" Foreground="#121518" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button.Content>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- 0: TabControl -->
                <RowDefinition Height="*" />    <!-- 1: LogViewer -->
                <RowDefinition Height="Auto" /> <!-- 2: Stats Panel -->
                <RowDefinition Height="Auto" /> <!-- 3: Progress Area -->
            </Grid.RowDefinitions>

            <TabControl Grid.Row="0" x:Name="MainTabControl" Margin="0,0,0,15" SelectionChanged="MainTabControl_SelectionChanged" Background="Transparent" BorderThickness="0">
                <TabItem Header="Convert to CHD" x:Name="ConvertTab">
                    <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="0,0,6,6" Padding="15">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Label Content="Source Files Folder:" />
                                <TextBox x:Name="ConversionInputFolderTextBox" Grid.Column="1" Margin="5,0" IsReadOnly="True" />
                                <Button x:Name="BrowseConversionInputButton" Grid.Column="2" Content="Browse..." Click="BrowseConversionInputButton_Click" Style="{StaticResource ActionButtonStyle}" />
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Label Content="Output CHD Folder:" />
                                <TextBox x:Name="ConversionOutputFolderTextBox" Grid.Column="1" Margin="5,0" IsReadOnly="True" />
                                <Button x:Name="BrowseConversionOutputButton" Grid.Column="2" Content="Browse..." Click="BrowseConversionOutputButton_Click" Style="{StaticResource ActionButtonStyle}" />
                            </Grid>

                            <GroupBox Header="Options" Margin="0,5,0,10" Padding="10">
                                <StackPanel>
                                    <CheckBox x:Name="DeleteOriginalsCheckBox" Content="Delete original files after successful conversion" Margin="0,5" HorizontalAlignment="Left" />
                                    <StackPanel Orientation="Horizontal" Margin="0,5">
                                        <CheckBox x:Name="ForceCreateCdCheckBox" Content="Force createcd (CD)" Margin="0,0,20,0" Checked="ForceCreateCdCheckBox_Checked" />
                                        <CheckBox x:Name="ForceCreateDvdCheckBox" Content="Force createdvd (DVD)" Checked="ForceCreateDvdCheckBox_Checked" />
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>

                            <Button x:Name="StartConversionButton" Content="Start Conversion" Click="StartConversionButton_Click" Style="{StaticResource StartButtonStyle}" HorizontalAlignment="Center" Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>
                </TabItem>

                <TabItem Header="Verify CHD Files" x:Name="VerifyTab">
                    <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="0,0,6,6" Padding="15">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Label Content="CHD Files Folder:" />
                                <TextBox x:Name="VerificationInputFolderTextBox" Grid.Column="1" Margin="5,0" IsReadOnly="True" />
                                <Button x:Name="BrowseVerificationInputButton" Grid.Column="2" Content="Browse..." Click="BrowseVerificationInputButton_Click" Style="{StaticResource ActionButtonStyle}" />
                            </Grid>

                            <GroupBox Header="Options" Margin="0,5,0,10" Padding="10">
                                <StackPanel>
                                    <CheckBox x:Name="MoveSuccessFilesCheckBox" Content="Move successfully tested CHD files to 'Success' folder" Margin="0,5" HorizontalAlignment="Left" />
                                    <CheckBox x:Name="MoveFailedFilesCheckBox" Content="Move failed tested CHD files to 'Failed' folder" Margin="0,5" HorizontalAlignment="Left" />
                                </StackPanel>
                            </GroupBox>

                            <Button x:Name="StartVerificationButton" Content="Start Verification" Click="StartVerificationButton_Click" Style="{StaticResource StartButtonStyle}" HorizontalAlignment="Center" Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>
                </TabItem>

                <TabItem Header="Extract from CHD" x:Name="ExtractTab">
                    <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="0,0,6,6" Padding="15">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Label Content="CHD Files Folder:" />
                                <TextBox x:Name="ExtractionInputFolderTextBox" Grid.Column="1" Margin="5,0" IsReadOnly="True" />
                                <Button x:Name="BrowseExtractionInputButton" Grid.Column="2" Content="Browse..." Click="BrowseExtractionInputButton_Click" Style="{StaticResource ActionButtonStyle}" />
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Label Content="Output Folder:" />
                                <TextBox x:Name="ExtractionOutputFolderTextBox" Grid.Column="1" Margin="5,0" IsReadOnly="True" />
                                <Button x:Name="BrowseExtractionOutputButton" Grid.Column="2" Content="Browse..." Click="BrowseExtractionOutputButton_Click" Style="{StaticResource ActionButtonStyle}" />
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <GroupBox Grid.Column="0" Header="Output Format" Margin="0,5,10,10" Padding="10">
                                    <StackPanel Orientation="Vertical">
                                        <RadioButton x:Name="ExtractAutoRadioButton" Content="Auto (detect)" IsChecked="True" Margin="0,2" />
                                        <RadioButton x:Name="ExtractCdRadioButton" Content="CD (.bin)" Margin="0,2" />
                                        <RadioButton x:Name="ExtractDvdRadioButton" Content="DVD (.iso)" Margin="0,2" />
                                        <RadioButton x:Name="ExtractHdRadioButton" Content="Hard Disk (.img)" Margin="0,2" />
                                    </StackPanel>
                                </GroupBox>

                                <GroupBox Grid.Column="1" Header="Options" Margin="10,5,0,10" Padding="10">
                                    <CheckBox x:Name="DeleteOriginalChdCheckBox" Content="Delete original CHD file after successful extraction" Margin="0,5" HorizontalAlignment="Left" VerticalAlignment="Top" VerticalContentAlignment="Top"/>
                                </GroupBox>
                            </Grid>

                            <Button x:Name="StartExtractionButton" Content="Start Extraction" Click="StartExtractionButton_Click" Style="{StaticResource StartButtonStyle}" HorizontalAlignment="Center" Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>
                </TabItem>
            </TabControl>

            <Border Grid.Row="1" BorderBrush="{StaticResource TerminalBorderBrush}" BorderThickness="2" CornerRadius="4" Background="{StaticResource TerminalBackgroundBrush}">
                <TextBox x:Name="LogViewer"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalAlignment="Stretch"
                         VerticalContentAlignment="Top"
                         IsReadOnly="True"
                         Padding="10"
                         FontFamily="Consolas"
                         FontSize="13"
                         Background="{StaticResource TerminalBackgroundBrush}"
                         Foreground="{StaticResource TerminalForegroundBrush}"
                         BorderThickness="0"
                         TextAlignment="Left"
                         TextWrapping="NoWrap"
                         CaretBrush="{StaticResource TerminalForegroundBrush}">
                    <TextBox.Effect>
                        <DropShadowEffect ShadowDepth="0" Color="#39FF14" BlurRadius="2" Opacity="0.4"/>
                    </TextBox.Effect>
                </TextBox>
            </Border>

            <Grid Grid.Row="2" Margin="0,15,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource StatCard}">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="TOTAL FILES" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock x:Name="TotalFilesValue" Text="0" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource StatCard}">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="SUCCESS" FontSize="10" Foreground="{StaticResource SuccessTextBrush}" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock x:Name="SuccessValue" Text="0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SuccessTextBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource StatCard}">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="FAILED" FontSize="10" Foreground="{StaticResource FailedTextBrush}" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock x:Name="FailedValue" Text="0" FontSize="18" FontWeight="Bold" Foreground="{StaticResource FailedTextBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource StatCard}">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="ELAPSED" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock x:Name="ProcessingTimeValue" Text="00:00:00" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <Border x:Name="SpeedStatCard" Grid.Column="4" Style="{StaticResource StatCard}">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="SPEED" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock x:Name="SpeedValue" Text="0.0 MB/s" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid x:Name="ProgressAreaGrid" Grid.Row="3" Margin="0,15,0,0" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="1" Background="{StaticResource CardBackgroundBrush}">
                    <Grid>
                        <ProgressBar x:Name="ProgressBar" Height="28" Foreground="{StaticResource ProgressForegroundBrush}" Background="{StaticResource ProgressBackgroundBrush}" BorderThickness="0" />
                        <TextBlock x:Name="ProgressText" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                    </Grid>
                </Border>
                <Button x:Name="CancelButton" Grid.Column="1" Content="Cancel" Style="{StaticResource CancelButtonStyle}" Margin="10,0,0,0" Click="CancelButton_Click" />
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Background="{StaticResource StatusBarBackgroundBrush}" Padding="5">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>

            <StatusBarItem Grid.Column="0">
                <TextBlock x:Name="StatusBarMessage" Text="Ready" Foreground="{StaticResource TextSecondaryBrush}" />
            </StatusBarItem>

            <StatusBarItem Grid.Column="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Dependencies:" Margin="0,0,5,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="StatusBarChdman" Text="CHDMAN" Foreground="{StaticResource SuccessTextBrush}" Margin="0,0,5,0"/>
                    <TextBlock Text="|" Margin="0,0,5,0" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock x:Name="StatusBarMaxcso" Text="MAXCSO" Foreground="{StaticResource SuccessTextBrush}" Margin="0,0,5,0"/>
                    <TextBlock Text="|" Margin="0,0,5,0" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock x:Name="StatusBarPsxPackager" Text="PSXPACKAGER" Foreground="{StaticResource SuccessTextBrush}" Margin="0"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>