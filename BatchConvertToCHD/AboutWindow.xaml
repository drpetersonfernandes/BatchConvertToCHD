<ui:FluentWindow x:Class="BatchConvertToCHD.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="About Batch Convert to CHD"
        Width="700" MinWidth="450"
        Height="700" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="About Batch Convert to CHD"
                     Icon="pack://application:,,,/images/logo.png"
                     ToolTip="About Batch Convert to CHD - Title bar" />

        <Grid Grid.Row="1" Margin="20" ToolTip="Application information and credits">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Logo Section -->
            <Border Grid.Row="0" Style="{StaticResource StatCard}" Margin="0,0,0,15" Padding="15" ToolTip="Application Logo">
                <StackPanel HorizontalAlignment="Center" ToolTip="Logo section">
                    <Image Width="{StaticResource AboutLogoSize}" Height="{StaticResource AboutLogoSize}" Source="pack://application:,,,/images/logo.png" ToolTip="Batch Convert to CHD application icon" />
                </StackPanel>
            </Border>

            <!-- Title & Version Section -->
            <Border Grid.Row="1" Style="{StaticResource StatCard}" Margin="0,0,0,15" Padding="15" ToolTip="Application name and version">
                <StackPanel ToolTip="Application name and version information">
                    <TextBlock Style="{StaticResource AboutTitleStyle}" Text="Batch Convert to CHD" ToolTip="Batch Convert to CHD" />
                    <TextBlock x:Name="AppVersionTextBlock" Margin="0,8,0,0" Text=""
                               Style="{StaticResource AboutSubtitleStyle}"
                               Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                               ToolTip="Current application version" />
                </StackPanel>
            </Border>

            <!-- Description Section -->
            <Border Grid.Row="2" Style="{StaticResource StatCard}" Margin="0,0,0,15" Padding="15" ToolTip="Brief overview of the application purpose">
                <StackPanel ToolTip="Description and project links">
                    <TextBlock Style="{StaticResource AboutSectionHeaderStyle}" Text="Description" Margin="0,0,0,10"
                               ToolTip="What this application does" />
                    <TextBlock x:Name="DescriptionTextBlock" Style="{StaticResource AboutBodyTextStyle}"
                               Text="" LineHeight="20"
                               ToolTip="Brief overview of the application and its capabilities" />
                    <TextBlock Margin="0,10,0,0" ToolTip="Project GitHub repository link">
                        <Hyperlink NavigateUri="https://github.com/drpetersonfernandes/BatchConvertToCHD" RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="{StaticResource LinkTextBrush}" TextDecorations="Underline" ToolTip="Visit the project repository">
                            https://github.com/drpetersonfernandes/BatchConvertToCHD
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock Margin="0,15,0,0" ToolTip="Official website link">
                        <Hyperlink NavigateUri="https://www.purelogiccode.com" RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="{StaticResource LinkTextBrush}" TextDecorations="Underline" ToolTip="Visit the official website">
                            https://www.purelogiccode.com
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Acknowledgements Section -->
            <Border Grid.Row="3" Style="{StaticResource StatCard}" Margin="0,0,0,15" Padding="15" ToolTip="Credits and third-party tools used">
                <StackPanel ToolTip="Acknowledgements and third-party tool attributions">
                    <TextBlock Style="{StaticResource AboutSectionHeaderStyle}" Text="Acknowledgements" Margin="0,0,0,10"
                               ToolTip="Credits and attributions for third-party tools used in this project" />
                    <TextBlock Margin="0,0,0,8" Style="{StaticResource AboutBodyTextStyle}"
                               ToolTip="Uses the CHDMAN tool from the MAME project for disc image conversion and verification">
                        <Run Text="Uses " />
                        <Hyperlink NavigateUri="https://github.com/mamedev/mame/" RequestNavigate="Hyperlink_RequestNavigate"
                                    Foreground="{DynamicResource AccentFillColorDefaultBrush}" FontWeight="Bold" TextDecorations="Underline"
                                    ToolTip="Visit the MAME/CHDMAN project on GitHub">CHDMAN</Hyperlink>
                        <Run Text=" from the MAME project for conversions and verifications." />
                    </TextBlock>
                    <TextBlock Margin="0,0,0,8" Style="{StaticResource AboutBodyTextStyle}"
                               ToolTip="Uses CSOSharp for CSO/CISO file decompression">
                        <Run Text="Uses " />
                        <Hyperlink NavigateUri="https://github.com/PureLogicCode/CSOSharp" RequestNavigate="Hyperlink_RequestNavigate"
                                    Foreground="{DynamicResource AccentFillColorDefaultBrush}" FontWeight="Bold" TextDecorations="Underline"
                                    ToolTip="Visit the CSOSharp project on GitHub">CSOSharp</Hyperlink>
                        <Run Text=" for .cso/.ciso decompression during conversion." />
                    </TextBlock>
                    <TextBlock Margin="0,0,0,8" Style="{StaticResource AboutBodyTextStyle}"
                               ToolTip="Uses PBPSharp for PlayStation PBP file handling">
                        <Run Text="Uses " />
                        <Hyperlink NavigateUri="https://github.com/PureLogicCode/PBPSharp" RequestNavigate="Hyperlink_RequestNavigate"
                                    Foreground="{DynamicResource AccentFillColorDefaultBrush}" FontWeight="Bold" TextDecorations="Underline"
                                    ToolTip="Visit the PBPSharp project on GitHub">PBPSharp</Hyperlink>
                        <Run Text=" for PlayStation .pbp file handling." />
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Close Button -->
            <ui:Button Grid.Row="4" Click="CloseButton_Click" Content="Close" Appearance="Primary"
                        HorizontalAlignment="Center" ToolTip="Close the About window" />
        </Grid>
    </Grid>
</ui:FluentWindow>
